# ── DATABASE (Supabase free tier) ──────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# ── JWT SECRETS ────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_64_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_ANOTHER_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── SERVER ─────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── SUPABASE STORAGE (free) ────────────────────
SUPABASE_URL=https://[YOUR-REF].supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
STORAGE_BUCKET=gharsaathi-uploads

# ── EMAIL (Gmail free SMTP) ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=GharSaathi <noreply@gharsaathi.in>

# ── SMS OTP (Fast2SMS free tier) ───────────────
FAST2SMS_API_KEY=your_fast2sms_key

# ── RATE LIMITING ──────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
